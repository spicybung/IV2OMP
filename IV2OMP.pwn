CMD:gotolc(playerid, params[])
{
    new targetid = playerid;

    if (params[0] != EOS)
    {
        if (sscanf(params, "u", targetid))
        {
            SendClientMessage(playerid, COLOR_USAGE, "Usage: /gotolc [playerid/name]");
            return 1;
        }

        if (!IsPlayerConnected(targetid))
        {
            SendClientMessage(playerid, COLOR_ERROR, "That player is not connected.");
            return 1;
        }
    }

    SetPlayerPos(targetid, 7073.799805, -1568.410034, 20.889999);

    if (targetid != playerid)
    {
        SendClientMessage(playerid, COLOR_INFO, "Player teleported to Liberty City IV.");
        SendClientMessage(targetid, COLOR_INFO, "You have been teleported to Liberty City IV.");
    }

    return 1;
}

CMD:day(playerid, params[])
{
    new hour = 12;

    if (params[0] != EOS)
    {
        if (sscanf(params, "i", hour))
        {
            SendClientMessage(playerid, COLOR_USAGE, "Usage: /day [hour 0-23]");
            return 1;
        }

        if (hour < 0 || hour > 23)
        {
            SendClientMessage(playerid, COLOR_ERROR, "World time must be from 0 to 23.");
            return 1;
        }
    }

    SetWorldTime(hour);
    return 1;
}

CMD:night(playerid, params[])
{
    new hour = 0;

    if (params[0] != EOS)
    {
        if (sscanf(params, "i", hour))
        {
            SendClientMessage(playerid, COLOR_USAGE, "Usage: /night [hour 0-23]");
            return 1;
        }

        if (hour < 0 || hour > 23)
        {
            SendClientMessage(playerid, COLOR_ERROR, "World time must be from 0 to 23.");
            return 1;
        }
    }

    SetWorldTime(hour);
    return 1;
}

public OnFilterScriptExit()
{
    return 1;
}